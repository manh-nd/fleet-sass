{
  "realm": "fleet",
  "enabled": true,
  "displayName": "Fleet Platform",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "accessTokenLifespan": 1800,
  "groups": [
    {
      "name": "tenants",
      "path": "/tenants",
      "subGroups": [
        {
          "name": "vinfast",
          "path": "/tenants/vinfast",
          "attributes": {
            "tenant_id": ["cf888888-8888-8888-8888-888888888888"],
            "tenant_type": ["ENTERPRISE"],
            "tenant_code": ["VF"],
            "region": ["VN"],
            "sub:fleet-notification-hub:status": ["ACTIVE"],
            "sub:fleet-notification-hub:expiry": ["2027-01-01T00:00:00Z"]
          },
          "subGroups": [
            {
              "name": "green-sm",
              "path": "/tenants/vinfast/green-sm",
              "attributes": {
                "tenant_id": ["aa999999-9999-9999-9999-999999999999"],
                "tenant_type": ["FLEET_OPERATOR"],
                "tenant_code": ["GSM"],
                "region": ["VN"],
                "sub:fleet-notification-hub:status": ["ACTIVE"],
                "sub:fleet-notification-hub:expiry": ["2027-01-01T00:00:00Z"]
              }
            },
            {
              "name": "v-green",
              "path": "/tenants/vinfast/v-green",
              "attributes": {
                "tenant_id": ["bb777777-7777-7777-7777-777777777777"],
                "tenant_type": ["PARTNER"],
                "tenant_code": ["VG"],
                "region": ["VN"],
                "sub:fleet-notification-hub:status": ["ACTIVE"],
                "sub:fleet-notification-hub:expiry": ["2026-12-31T23:59:59Z"]
              }
            }
          ]
        },
        {
          "name": "avocado-transport",
          "path": "/tenants/avocado-transport",
          "attributes": {
            "tenant_id": ["11111111-1111-1111-1111-111111111111"],
            "tenant_type": ["FLEET_OPERATOR"],
            "tenant_code": ["AVO"],
            "region": ["NA"],
            "sub:fleet-notification-hub:status": ["ACTIVE"],
            "sub:fleet-notification-hub:expiry": ["2026-12-31T23:59:59Z"]
          }
        },
        {
          "name": "blue-fleet",
          "path": "/tenants/blue-fleet",
          "attributes": {
            "tenant_id": ["22222222-2222-2222-2222-222222222222"],
            "tenant_type": ["FLEET_OPERATOR"],
            "tenant_code": ["BLUE"],
            "region": ["EU"],
            "sub:fleet-notification-hub:status": ["SUSPENDED"],
            "sub:fleet-notification-hub:expiry": ["2025-06-30T23:59:59Z"]
          }
        }
      ]
    }
  ],
  "roles": {
    "client": {
      "fleet-notification-hub": [
        { "name": "notification:send", "description": "Permission to send notifications" },
        { "name": "notification:view-logs", "description": "Permission to view delivery history" },
        { "name": "template:manage", "description": "Permission to create/edit templates" },
        { "name": "config:manage", "description": "Permission to manage channels" },
        { 
          "name": "sender", 
          "description": "Composite role for notification senders",
          "composite": true,
          "composites": {
            "client": { "fleet-notification-hub": [ "notification:send" ] }
          }
        },
        {
          "name": "manager",
          "description": "Composite role for business managers",
          "composite": true,
          "composites": {
            "client": { "fleet-notification-hub": [ "sender", "template:manage" ] }
          }
        },
        {
          "name": "admin",
          "description": "Full access to Fleet Notification Hub",
          "composite": true,
          "composites": {
            "client": { "fleet-notification-hub": [ "manager", "config:manage", "notification:view-logs" ] }
          }
        }
      ]
    }
  },
  "clients": [
    {
      "clientId": "fleet-notification-hub",
      "name": "Fleet Notification Hub",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "fullScopeAllowed": false,
      "secret": "${KEYCLOAK_CLIENT_SECRET:fleet-secret-change-in-prod}",
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:8080/swagger-ui/oauth2-redirect.html",
        "http://localhost:8080/*"
      ],
      "protocolMappers": [
        {
          "name": "tenant-groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "tenants"
          }
        },
        {
          "name": "client-roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-client-role-mapper",
          "config": {
            "access.token.claim": "false",
            "id.token.claim": "false",
            "userinfo.token.claim": "true",
            "claim.name": "resource_access.${client_id}.roles",
            "jsonType.label": "String",
            "multivalued": "true",
            "usermodel.clientRoleMapping.clientId": "fleet-notification-hub"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@fleet.io",
      "credentials": [{ "type": "password", "value": "admin", "temporary": false }],
      "clientRoles": { "fleet-notification-hub": [ "admin" ] }
    },
    {
      "username": "gsm-operator",
      "enabled": true,
      "email": "ops@green-sm.vn",
      "credentials": [{ "type": "password", "value": "password123", "temporary": false }],
      "clientRoles": { "fleet-notification-hub": [ "sender" ] },
      "groups": [ "/tenants/vinfast/green-sm" ]
    },
    {
      "username": "vf-manager",
      "enabled": true,
      "email": "manager@vinfast.vn",
      "credentials": [{ "type": "password", "value": "password123", "temporary": false }],
      "clientRoles": { "fleet-notification-hub": [ "manager" ] },
      "groups": [ "/tenants/vinfast" ]
    }
  ]
}


